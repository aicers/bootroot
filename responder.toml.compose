# HTTP-01 Responder Docker Compose Config

listen_addr = "0.0.0.0:80"
admin_addr = "0.0.0.0:8080"
# hmac_secret must be set to a unique, random value before deployment.
# Example: openssl rand -hex 32
hmac_secret = "CHANGE-ME"
token_ttl_secs = 300
max_token_ttl_secs = 900
cleanup_interval_secs = 30
max_skew_secs = 60
admin_rate_limit_requests = 300
admin_rate_limit_window_secs = 60
admin_body_limit_bytes = 8192
